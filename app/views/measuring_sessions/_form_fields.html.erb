<%= f.text_field :device_description %>

<%= f.select :measuring_point_number, @measuring_points.map { |mp| [ mp.name, mp.number ] } %>

<%= f.check_box :autoreload_disabled %>

<%= f.check_box :hide_team_names %>

<%= f.number_field :autosave_delay_ms,
      append: "ms",
      help: "Automatisch im Hintergrund speichern nach der angegebenen Inaktivitätsdauer. Auf 0 oder negativ setzen, um den automatischen Speichervorgang zu deaktivieren." %>
<br>