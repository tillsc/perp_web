<h1>Ehrung</h1>

<% if @races.empty? %>
  <p class="text-muted mt-3">Keine Rennen zur Ehrung ausstehend.</p>
<% else %>
  <% @races.each do |race| %>
    <div class="card mb-4">
      <div class="card-header d-flex justify-content-between align-items-center">
        <%= link_to race.full_name(show_event_name_short: true), announcer_results_path(@regatta, race.event_number, race.number), class: "fw-bold text-reset" %>
        <% if can?(:honor, race) %>
          <%= button_to "Als geehrt markieren",
                announcer_honor_path(@regatta, race.event.number, race.number, referrer: current_url),
                method: :patch,
                class: "btn btn-success btn-sm" %>
        <% end %>
      </div>
      <div class="card-body py-2">
        <% entries = race.honor_entries(@regatta) %>
        <% if entries.empty? %>
          <span class="text-muted">Keine Ergebnisse verfügbar.</span>
        <% else %>
          <% mp_number = race.event.finish_measuring_point_number %>
          <% entries.each do |result| %>
            <div class="mb-2">
              <div class="d-flex align-items-center gap-2">
                <span class="badge bg-secondary"><%= result.rank %>.</span>
                <%= result.participant.team_name(regatta: @regatta, hide_age_category: true) %>
                <% cat = result.participant.age_category(regatta: @regatta) %>
                <% if cat %>
                  <span class="badge bg-info text-dark"><%= cat %></span>
                <% end %>
                <small class="text-muted">Bugnr. <%= link_to result.participant.number, participant_path(@regatta, result.participant.event_number, result.participant.participant_id), target: 'announcer-participant' %></small>
                <% if (t = result.time_for(mp_number)&.time) %>
                  <span class="text-muted">&middot; <%= t %></span>
                <% end %>
              </div>
              <div class="text-muted ms-4">
                <%= result.participant.rower_names(rower_link: rower_link_proc(link_to_options: { target: 'announcer-rower' })) %>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
      <div class="card-footer text-muted small text-end">
        <%= race.state_text %>
        <% if race.referee_finish_judge %>
          &middot; Zielrichter: <%= race.referee_finish_judge.name %>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>

<script>
  autoreloadAfter(10000)
</script>
