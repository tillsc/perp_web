<%= render 'header' %>

<p class="text-muted mb-0">Ruderer</p>
<h3 class="mb-1"><%= @rower.first_name %> <%= @rower.last_name %></h3>
<p class="text-muted mb-3">
  <%= @rower.year_of_birth.presence %>
  <% club_name = @rower.club&.name || @rower.club_name %>
  <%= "&middot; #{ERB::Util.html_escape(club_name)}".html_safe if club_name.present? %>
</p>


<% if @results.present? || @starts.present? %>
  <h4>Starts &amp; Ergebnisse</h4>
  <%= render 'results_and_starts', results: @results, starts: @starts %>
<% end %>

<% if @other_participants.any? %>
  <h4 class="mt-3">Andere Regatten</h4>
  <table class="table table-striped small">
    <thead>
      <tr>
        <th><%= Regatta.model_name.human %></th>
        <th><%= Event.model_name.human %></th>
        <th><%= Participant.human_attribute_name(:number) %></th>
        <th><%= Participant.human_attribute_name(:team) %></th>
      </tr>
    </thead>
    <tbody>
      <% @other_participants.each do |participant| %>
        <% next unless participant.regatta %>
        <tr>
          <td><%= participant.regatta.name %></td>
          <td><%= link_to participant.event.label, event_participants_url(participant.regatta, participant.event.number) %></td>
          <td><%= link_to participant.number, participant_path(participant.regatta, participant.event_number, participant.participant_id) if participant.number %></td>
          <td><%= participant.team_name(regatta: @regatta) %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<script>
  autoreloadAfter(60000)
</script>
