<%= bootstrap_form_for @team, url:
  @team.persisted? ? internal_team_url(@regatta, @team) : internal_teams_url(@regatta) do |f| %>
  <%= hidden_field_tag :referrer, params[:referrer] %>

  <div class="row">
    <div class="col-md-4">
      <tagged-name-input href="<%= internal_addresses_url(@regatta, only_role: 'club') %>">
        <%= f.text_field :name, required: true %>
      </tagged-name-input>
      <%= f.text_field :country %>
      <%= f.text_field :city %>

    </div>

    <div class="col-md-4">
      <dialog-opener move-out="primary" local-reload id="dialog-opener-representative">
        <%= content_tag 'find-reference', href: internal_addresses_url(@regatta, only_role: "representative"),
                        'value-field': 'address_id', 'label-field': 'name',
                        'initial-label': f.object.representative&.name do %>
          <%= f.text_field :representative_id, required: true,
                           append: (can?(:create, Address) ? link_to("+", new_internal_address_url(@regatta, address: {is_representative: 1}, referrer: current_url), class: "btn btn-secondary") : nil) %>
        <% end %>
      </dialog-opener>
    </div>

    <div class="col-md-4">
      <%= f.check_box :no_entry_fee %>
      <%= f.number_field :entry_fee_discount, append: @regatta.currency %>
    </div>
  </div>

  <%= f.primary %>
  <%= link_to "Abbrechen", back_or_default, class: 'btn btn-secondary' %>
<% end %>