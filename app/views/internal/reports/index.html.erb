<%= render 'regatta/header' %>

<h2>Ausdrucke</h2>

<ul class="nav nav-tabs mb-3" role="tablist">
  <li class="nav-item">
    <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-results" type="button"><%= Result.model_name.human(count: 2) %></button>
  </li>
  <li class="nav-item">
    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-participants" type="button">Meldeergebnis</button>
  </li>
  <li class="nav-item">
    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-starts" type="button">Startlisten</button>
  </li>
  <li class="nav-item">
    <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-rowers" type="button"><%= Rower.model_name.human(count: 2) %></button>
  </li>
</ul>

<div class="tab-content">
  <div class="tab-pane fade show active" id="tab-results">
    <%= render 'internal/reports/results/form' %>
  </div>
  <div class="tab-pane fade" id="tab-participants">
    <%= render 'internal/reports/participants/form' %>
  </div>
  <div class="tab-pane fade" id="tab-starts">
    <%= render 'internal/reports/starts/form' %>
  </div>
  <div class="tab-pane fade" id="tab-rowers">
    <%= render 'internal/reports/rowers/form' %>
  </div>
</div>
